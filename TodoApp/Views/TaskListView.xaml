<UserControl x:Class="TodoApp.Views.TaskListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:models="clr-namespace:TodoApp.Models">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Tasks" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundPrimary}"/>
                <TextBlock Text="Manage your tasks" FontSize="13"
                           Foreground="{DynamicResource ForegroundSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Command="{Binding OpenAddDialogCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource PlusIcon}" Fill="White"
                          Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="Add Task"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- Search + Filter bar -->
        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBox DockPanel.Dock="Left" Style="{StaticResource SearchTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="300" Tag="Search tasks..."/>

            <!-- Sort -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Path Data="{StaticResource SortIcon}" Fill="{DynamicResource ForegroundMuted}"
                      Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Style="{StaticResource ModernComboBox}" Width="130"
                          SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="Deadline" IsSelected="True" Tag="Deadline"/>
                    <ComboBoxItem Content="Priority" Tag="Priority"/>
                    <ComboBoxItem Content="Category" Tag="Category"/>
                    <ComboBoxItem Content="Title" Tag="Title"/>
                    <ComboBoxItem Content="Created" Tag="Created"/>
                </ComboBox>
            </StackPanel>

            <!-- Category filter chips -->
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <Button Content="All" Style="{StaticResource GhostButton}"
                        Command="{Binding ClearCategoryFilterCommand}"
                        Margin="0,0,4,0"/>
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource GhostButton}" Margin="0,0,4,0"
                                    Click="CategoryFilter_Click" Tag="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding Color, Converter={StaticResource HexToColor}}"
                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DockPanel>

        <!-- Task list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TasksView}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TodoTaskViewModel}">
                        <Border Style="{StaticResource TaskCard}"
                                Opacity="{Binding IsCompleted, Converter={StaticResource BoolToOpacity}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Completion checkbox -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                          VerticalAlignment="Center" Margin="0,0,12,0"
                                          Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>

                                <!-- Priority indicator -->
                                <Ellipse Grid.Column="1" Width="10" Height="10"
                                         Fill="{Binding Priority, Converter={StaticResource PriorityToColor}}"
                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                         ToolTip="{Binding Priority}"/>

                                <!-- Title + Tags -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14"
                                               Foreground="{DynamicResource ForegroundPrimary}"
                                               TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethrough}}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- Tags row -->
                                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Color, Converter={StaticResource HexToColor}}"
                                                        CornerRadius="4" Padding="6,2" Margin="0,0,4,0" Opacity="0.8">
                                                    <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Category badge -->
                                <Border Grid.Column="3" CornerRadius="4" Padding="8,4" Margin="8,0"
                                        VerticalAlignment="Center"
                                        Background="{Binding CategoryColor, Converter={StaticResource HexToColor}}"
                                        Opacity="0.85">
                                    <TextBlock Text="{Binding CategoryName}" FontSize="11" Foreground="White"/>
                                </Border>

                                <!-- Deadline -->
                                <TextBlock Grid.Column="4" Text="{Binding DeadlineText}"
                                           FontSize="12" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Edit">
                                        <Path Data="{StaticResource EditIcon}"
                                              Fill="{DynamicResource ForegroundSecondary}"
                                              Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Delete">
                                        <Path Data="{StaticResource DeleteIcon}"
                                              Fill="{DynamicResource ForegroundSecondary}"
                                              Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add/Edit Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100"
                Background="{DynamicResource DialogOverlay}"
                Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}"
                MouseLeftButtonDown="DialogOverlay_Click">
            <Border Background="{DynamicResource BackgroundSecondary}"
                    CornerRadius="16" Padding="32"
                    MaxWidth="480" MaxHeight="620"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Dialog header -->
                        <DockPanel Margin="0,0,0,24">
                            <TextBlock FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource ForegroundPrimary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Add Task"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Text" Value="Edit Task"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding CancelDialogCommand}"
                                    HorizontalAlignment="Right">
                                <Path Data="{StaticResource CloseIcon}"
                                      Fill="{DynamicResource ForegroundSecondary}"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </DockPanel>

                        <!-- Title -->
                        <TextBlock Text="Title" FontSize="12" Foreground="{DynamicResource ForegroundSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding EditingTask.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Enter task title..." Margin="0,0,0,16"/>

                        <!-- Notes -->
                        <TextBlock Text="Notes" FontSize="12" Foreground="{DynamicResource ForegroundSecondary}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding EditingTask.Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Optional notes..." AcceptsReturn="True"
                                 Height="60" TextWrapping="Wrap"
                                 Margin="0,0,0,16"/>

                        <!-- Category + Priority row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Category" FontSize="12"
                                           Foreground="{DynamicResource ForegroundSecondary}" Margin="0,0,0,6"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding Categories}"
                                          SelectedValue="{Binding EditingTask.CategoryId}"
                                          SelectedValuePath="Id" DisplayMemberPath="Name"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Priority" FontSize="12"
                                           Foreground="{DynamicResource ForegroundSecondary}" Margin="0,0,0,6"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          SelectedValue="{Binding EditingTask.Priority}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Low" Tag="{x:Static models:Priority.Low}"/>
                                    <ComboBoxItem Content="Medium" Tag="{x:Static models:Priority.Medium}"/>
                                    <ComboBoxItem Content="High" Tag="{x:Static models:Priority.High}"/>
                                    <ComboBoxItem Content="Critical" Tag="{x:Static models:Priority.Critical}"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Deadline + Recurrence row -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Deadline" FontSize="12"
                                           Foreground="{DynamicResource ForegroundSecondary}" Margin="0,0,0,6"/>
                                <DatePicker SelectedDate="{Binding EditingTask.Deadline}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Recurrence" FontSize="12"
                                           Foreground="{DynamicResource ForegroundSecondary}" Margin="0,0,0,6"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          SelectedValue="{Binding EditingTask.Recurrence}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="None" Tag="{x:Static models:RecurrenceType.None}"/>
                                    <ComboBoxItem Content="Daily" Tag="{x:Static models:RecurrenceType.Daily}"/>
                                    <ComboBoxItem Content="Weekly" Tag="{x:Static models:RecurrenceType.Weekly}"/>
                                    <ComboBoxItem Content="Monthly" Tag="{x:Static models:RecurrenceType.Monthly}"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Style="{StaticResource GhostButton}"
                                    Command="{Binding CancelDialogCommand}" Margin="0,0,12,0"/>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SaveTaskCommand}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Add Task"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Text" Value="Save Changes"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding TasksView.IsEmpty, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
            <Path Data="{StaticResource TasksIcon}" Fill="{DynamicResource ForegroundMuted}"
                  Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="No tasks yet" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}" HorizontalAlignment="Center"/>
            <TextBlock Text="Click 'Add Task' to get started" FontSize="13"
                       Foreground="{DynamicResource ForegroundMuted}" HorizontalAlignment="Center"
                       Margin="0,8,0,16"/>
            <Button Style="{StaticResource PrimaryButton}" Command="{Binding OpenAddDialogCommand}"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource PlusIcon}" Fill="White"
                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                    <TextBlock Text="Add Task"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
