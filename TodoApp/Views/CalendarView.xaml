<UserControl x:Class="TodoApp.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Calendar" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource ForegroundPrimary}"/>
            <TextBlock Text="View tasks by date" FontSize="13"
                       Foreground="{DynamicResource ForegroundSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Month navigation -->
        <DockPanel Grid.Row="1" Margin="0,0,0,16" HorizontalAlignment="Center">
            <Button Style="{StaticResource IconButton}" Command="{Binding PreviousMonthCommand}"
                    DockPanel.Dock="Left">
                <Path Data="{StaticResource ChevronLeftIcon}" Fill="{DynamicResource ForegroundPrimary}"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>

            <TextBlock Text="{Binding MonthYearText}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundPrimary}"
                       VerticalAlignment="Center" Margin="16,0"
                       MinWidth="180" TextAlignment="Center"/>

            <Button Style="{StaticResource IconButton}" Command="{Binding NextMonthCommand}"
                    DockPanel.Dock="Right">
                <Path Data="{StaticResource ChevronRightIcon}" Fill="{DynamicResource ForegroundPrimary}"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>
        </DockPanel>

        <!-- Day of week headers -->
        <UniformGrid Grid.Row="2" Columns="7" Margin="0,0,0,8">
            <TextBlock Text="Mon" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Tue" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Wed" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Thu" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Fri" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Sat" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
            <TextBlock Text="Sun" HorizontalAlignment="Left" Margin="4,0,0,0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundMuted}"/>
        </UniformGrid>

        <!-- Calendar grid -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding Days}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:CalendarDayViewModel}">
                    <Border x:Name="DayCellBorder" Style="{StaticResource CalendarDayCell}" MinHeight="80"
                            Cursor="Hand"
                            Tag="{Binding}">
                        <Border.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Border.Background>
                        <Grid>
                            <StackPanel Margin="4">
                                <!-- Day number -->
                                <TextBlock Text="{Binding DayNumber}" FontSize="14"
                                           HorizontalAlignment="Left">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundMuted}"/>
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Task indicators -->
                                <ItemsControl ItemsSource="{Binding Tasks}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CategoryColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="3" Padding="4,1" Margin="0,1"
                                                    Opacity="0.85" MaxWidth="100">
                                                <TextBlock Text="{Binding Title}" FontSize="9"
                                                           Foreground="White"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Add task button (visible on hover) -->
                            <Button x:Name="AddTaskButton"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,2,2,0" Width="20" Height="20"
                                    Cursor="Hand" Opacity="0" IsHitTestVisible="False"
                                    Click="AddTaskButton_Click"
                                    Tag="{Binding}"
                                    ToolTip="Add task on this day">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="10" Width="20" Height="20">
                                                        <Path Data="{StaticResource PlusIcon}"
                                                              Fill="White" Width="10" Height="10"
                                                              Stretch="Uniform"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="DayCellBorder" Property="IsMouseOver" Value="True">
                            <Setter TargetName="AddTaskButton" Property="Opacity" Value="1"/>
                            <Setter TargetName="AddTaskButton" Property="IsHitTestVisible" Value="True"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
