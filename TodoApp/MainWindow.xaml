<Window x:Class="TodoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoApp.ViewModels"
        Title="TODO App" Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimary}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskShortcutCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding ToggleThemeCommand}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding NavigateToTasksCommand}"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding NavigateToCalendarCommand}"/>
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding NavigateToSettingsCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo area -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,32">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="36" Height="36">
                            <Ellipse Fill="{DynamicResource AccentBrush}"/>
                            <Path Data="{StaticResource CheckIcon}" Fill="White"
                                  Width="18" Height="18" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="TODO" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource ForegroundPrimary}"/>
                            <TextBlock Text="Get things done" FontSize="10"
                                       Foreground="{DynamicResource ForegroundMuted}"
                                       Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Nav label -->
                <TextBlock DockPanel.Dock="Top" Text="MENU" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundMuted}"
                           Margin="28,0,0,8"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Content="Dashboard" Style="{StaticResource NavButton}"
                                 Tag="{StaticResource DashboardIcon}"
                                 Command="{Binding NavigateToDashboardCommand}"/>
                    <RadioButton Content="Tasks" Style="{StaticResource NavButton}"
                                 Tag="{StaticResource TasksIcon}"
                                 Command="{Binding NavigateToTasksCommand}"
                                 IsChecked="True"/>
                    <RadioButton Content="Calendar" Style="{StaticResource NavButton}"
                                 Tag="{StaticResource CalendarIcon}"
                                 Command="{Binding NavigateToCalendarCommand}"/>
                </StackPanel>

                <!-- Settings at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="20,0,20,8"/>
                    <RadioButton Content="Settings" Style="{StaticResource NavButton}"
                                 Tag="{StaticResource SettingsIcon}"
                                 Command="{Binding NavigateToSettingsCommand}"/>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundPrimary}">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>
        </Border>

        <!-- Toast notification area -->
        <Border Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,24,24">
            <ItemsControl ItemsSource="{Binding Toasts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16,12" Margin="0,4,0,0" MinWidth="280">
                            <DockPanel>
                                <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                         Fill="{Binding Color}" Margin="0,0,10,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}" FontSize="13"
                                           Foreground="{DynamicResource ForegroundPrimary}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
