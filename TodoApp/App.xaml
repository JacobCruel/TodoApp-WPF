<Application x:Class="TodoApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:views="clr-namespace:TodoApp.Views"
             xmlns:converters="clr-namespace:TodoApp.Converters"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Resources/Icons/IconGeometries.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/CardStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:PriorityToColorConverter x:Key="PriorityToColor"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibility" Invert="True"/>
            <converters:HexToColorConverter x:Key="HexToColor"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <converters:BoolToStrikethroughConverter x:Key="BoolToStrikethrough"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>

            <!-- DataTemplate mappings: ViewModel → View -->
            <DataTemplate DataType="{x:Type vm:TaskListViewModel}">
                <views:TaskListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CalendarViewModel}">
                <views:CalendarView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
