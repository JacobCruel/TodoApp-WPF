<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BackgroundPrimary" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="#16213E"/>
    <SolidColorBrush x:Key="BackgroundTertiary" Color="#0F3460"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#0D1117"/>
    <SolidColorBrush x:Key="CardBackground" Color="#1E2D3D"/>
    <SolidColorBrush x:Key="DialogOverlay" Color="#DD000000"/>

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="ForegroundPrimary" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ForegroundSecondary" Color="#8B949E"/>
    <SolidColorBrush x:Key="ForegroundMuted" Color="#484F58"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#E94560"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF6B81"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#C23152"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FF9800"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#F44336"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2196F3"/>

    <!-- Interactive -->
    <SolidColorBrush x:Key="HoverBrush" Color="#21262D"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#1C2333"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
    <SolidColorBrush x:Key="InputBackground" Color="#0D1117"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#30363D"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#E94560"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBarThumb" Color="#484F58"/>
    <SolidColorBrush x:Key="ScrollBarTrack" Color="Transparent"/>

</ResourceDictionary>
